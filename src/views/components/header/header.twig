{#
| Variable         | Type    | Description                     |
|------------------|---------|---------------------------------|
| cart             | object  |                                 |
| cart.items_count | int     |                                 |
| cart.total       | string  | Formatted total ex: "١٠٠ ر.س"   |
#}


<header class="store-header group">
  {# Top Highlight Bar (Optional, can be hidden via settings) #}
  {% if theme.settings.get('important_links') %}
  <div class="top-navbar bg-gray-50 border-b border-gray-100 text-xs py-1.5 hidden md:block">
    <div class="container flex justify-between items-center">
       <div class="flex items-center gap-4">
         <salla-social class="text-gray-400"></salla-social>
       </div>
       <div class="flex items-center gap-4">
          {% if store.settings.is_multilingual or store.settings.currencies_enabled %}
              <button type="button" onclick="salla.event.dispatch('localization::open')" class="flex items-center gap-1 hover:text-primary transition-colors">
                  <i class="sicon-globe"></i>
                  <span>{{ user.language.name }}</span>
                  <span class="mx-1 opacity-50">|</span> 
                  <span>{{ currency.symbol }}</span>
              </button>
              <salla-localization-modal></salla-localization-modal>
          {% endif %}
       </div>
    </div>
  </div>
  {% endif %}

  {# Main Header #}
  <div id="mainnav" class="main-nav-container bg-white transition-all duration-300 w-full z-40 relative border-b border-gray-100">
      <div class="container">
          <div class="flex items-center justify-between h-[80px]">
              {# 1. Start: Logo & Mobile Toggle #}
              <div class="flex items-center gap-4 shrink-0">
                  <a class="lg:hidden text-2xl text-gray-700" href="#mobile-menu" aria-label="Open-menu">
                    <i class="sicon-menu"></i>
                  </a>
                  <a class="navbar-brand block" href="{{ store.url }}">
                      <img fetchpriority="high" loading="eager" src="{{ store.logo|cdn(180) }}" alt="{{ store.name }} logo" class="max-h-[50px] w-auto">
                      <h1 class="sr-only">{{ store.name }}</h1>
                  </a>
              </div>

              {# 2. Center: Navigation Menu #}
              <div class="hidden lg:flex flex-1 justify-center px-8">
                  <custom-main-menu></custom-main-menu>
              </div>

              {# 3. End: Actions (Search, User, Cart) #}
              <div class="flex items-center gap-3 shrink-0">
                  {# Search: Icon that expands or clean input #}
                  <div class="hidden sm:block min-w-[200px]">
                    <salla-search inline oval height="42"></salla-search>
                  </div>

                  {# User Actions #}
                  <div class="flex items-center gap-2">
                       {% if user.type=='user' %}
                         <salla-user-menu avatar-only show-header></salla-user-menu>
                       {% else %}
                           <button class="w-10 h-10 flex items-center justify-center rounded-full hover:bg-gray-50 text-gray-600 transition-colors" onclick="salla.event.dispatch('login::open')" aria-label="Login">
                             <i class="sicon-user-circle text-2xl"></i>
                           </button>
                       {% endif %}
                       
                       <salla-cart-summary class="ml-0">
                         <div slot="icon" class="w-10 h-10 flex items-center justify-center rounded-full hover:bg-gray-50 text-gray-600 transition-colors cursor-pointer relative">
                            <i class="sicon-shopping-bag text-2xl"></i>
                         </div>
                       </salla-cart-summary>
                  </div>
              </div>
          </div>
      </div>
  </div>
</header>
